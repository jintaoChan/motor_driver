{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "toolchainFile": "${sourceDir}/cmake/gcc-arm-none-eabi.cmake",
            "cacheVariables": {}
        },
        {
            "name": "linux-ninja",
            "hidden": true,
            "inherits": "default",
            "cacheVariables": {}
        },
        {
            "name": "windows-ninja",
            "hidden": true,
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_MAKE_PROGRAM": "$env{CMAKE_MAKE_PROGRAM}"
            }
        },
        {
            "name": "Debug",
            "inherits": "linux-ninja",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "Debug-Windows",
            "inherits": "windows-ninja",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "Release",
            "inherits": "windows-ninja",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "Release-Windows",
            "inherits": "windows-ninja",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "Debug",
            "configurePreset": "Debug"
        },
        {
            "name": "Debug-Windows",
            "configurePreset": "Debug-Windows"
        },
        {
            "name": "Release",
            "configurePreset": "Release"
        },
        {
            "name": "Release-Windows",
            "configurePreset": "Release-Windows"
        }
    ]
}