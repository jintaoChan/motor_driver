{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (OpenOCD + ST-Link)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "serverpath": "D:/xpack-openocd-0.12.0-7-win32-x64/xpack-openocd-0.12.0-7/bin/openocd.exe",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/Debug/motor_driver.elf",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32g4x.cfg"
            ],
            "svdFile": "${env:CUBE_BUNDLE_PATH}/packs/Keil/STM32G4xx_DFP/1.5.0/CMSIS/SVD/STM32G474xx.svd",
            "preLaunchTask": "Build Debug",
            "showDevDebugOutput": "none",
            "armToolchainPath": "${env:CUBE_BUNDLE_PATH}/gnu-tools-for-stm32/14.3.1+st.2/bin"
        },
        {
            "name": "Debug (ST-Link GDB Server)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "stlink",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/Debug/motor_driver.elf",
            "device": "STM32G474RET6",
            "svdFile": "${env:CUBE_BUNDLE_PATH}/packs/Keil/STM32G4xx_DFP/1.5.0/CMSIS/SVD/STM32G474xx.svd",
            "preLaunchTask": "Build Debug",
            "showDevDebugOutput": "none",
            "armToolchainPath": "${env:CUBE_BUNDLE_PATH}/gnu-tools-for-stm32/14.3.1+st.2/bin"
        }
    ]
}
